{
  "expo": {
    "name": "ChaChing Social",
    "slug": "chaching-mobile-app",
    "version": "1.1.1",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "myapp",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "entitlements": {
        "com.apple.developer.applesignin": [
          "Default"
        ]
      },
      "googleServicesFile": "./GoogleService-Info.plist",
      "supportsTablet": true,
      "bundleIdentifier": "com.sonylomo.chachingmobileapp",
      "infoPlist": {
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true
        },
        "NSPhotoLibraryUsageDescription": "ChaChing Social needs access to your photo library so you can choose photos or videos to upload to posts, events, and your profile. We only access items you select.",
        "NSPhotoLibraryAddUsageDescription": "ChaChing Social uses this permission to save images you choose (for example, a photo you download or export from the app) to your photo library.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "androidStatusBar": {
      "backgroundColor": "#000000"
    },
    "android": {
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#FFFFFF"
      },
      "package": "com.sonylomo.chachingmobileapp",
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-apple-authentication",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow ChaChing Social to access only the photos or videos you select so you can upload them to posts, events, or your profile."
        }
      ],
      "@react-native-google-signin/google-signin",
      "@react-native-firebase/app",
      "@react-native-firebase/auth",
      [
        "expo-build-properties",
        {
          "ios": {
            "useFrameworks": "static",
            "buildReactNativeFromSource": true
          }
        }
      ],
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-screen.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#000000"
        }
      ],
      "expo-secure-store",
      "expo-font",
      "expo-web-browser",
      [
        "expo-video",
        {
          "supportsBackgroundPlayback": true,
          "supportsPictureInPicture": true
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "1092fdb1-cf0d-4901-96de-dc096aefad17"
      }
    },
    "owner": "chaching-social"
  }
}
